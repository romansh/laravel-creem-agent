{
    "name": "romansh/laravel-creem-agent",
    "version": "1.2.8",
    "description": "Autonomous AI agent for Creem.io store monitoring — heartbeat, proactive workflows, notifications, chat interface",
    "keywords": ["laravel", "creem", "agent", "ai", "heartbeat", "monitoring", "saas"],
    "license": "MIT",
    "type": "library",
    "repositories": [
        { "type": "vcs", "url": "git@github-laravel-creem-desktop:romansh/laravel-creem.git", "no-api": true },
        { "type": "vcs", "url": "git@github-laravel-creem-cli-desktop:romansh/laravel-creem-cli.git", "no-api": true }
    ],
    "require": {
        "php": "^8.2",
        "romansh/laravel-creem": "^1.0",
        "romansh/laravel-creem-cli": "^1.0 || dev-main",
        "laravel/ai": "^0.4",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/notifications": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Romansh\\LaravelCreemAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Romansh\\LaravelCreemAgent\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Romansh\\LaravelCreemAgent\\CreemAgentServiceProvider"
            ],
            "aliases": {
                "CreemCli": "Romansh\\LaravelCreemAgent\\Facades\\CreemCli"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "use-github-api": false,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
