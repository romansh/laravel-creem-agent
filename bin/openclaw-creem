#!/bin/sh
# Simple OpenClaw-compatible helper to forward text to the local Creem agent
# Usage: openclaw-creem "your message"  OR  echo "your message" | openclaw-creem

AGENT_URL="${OPENCLAW_AGENT_URL:-http://127.0.0.1:8000}/creem-agent/chat"

if [ -t 0 ] && [ -z "$1" ]; then
  echo "Usage: $0 \"message\"  or  echo \"message\" | $0"
  exit 2
fi

if [ -n "$1" ]; then
  MSG="$1"
else
  MSG=$(cat -)
fi

# Use jq if available for safe JSON quoting, otherwise use a basic fallback
if command -v jq >/dev/null 2>&1; then
  PAYLOAD=$(jq -Rn --arg m "$MSG" '{message:$m,source:"openclaw"}')
else
  # Escape simple double quotes and backslashes
  ESC=$(printf '%s' "$MSG" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null)
  if [ -z "$ESC" ]; then
    ESC=""
  fi
  PAYLOAD="{\"message\":$ESC,\"source\":\"openclaw\"}"
fi

curl -s -X POST "$AGENT_URL" -H 'Content-Type: application/json' -d "$PAYLOAD"
